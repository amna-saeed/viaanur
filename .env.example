APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Comma-separated emails that always get admin role (same as your login email)
ADMIN_EMAILS=
# LMS: false = normal student/admin split. true = everyone admin, student URLs redirect to admin.
ADMIN_ONLY_MODE=false
# LMS: allow choosing "Admin" on /register (keep false in production; first user can still pick Admin if no admin exists)
ALLOW_ADMIN_REGISTRATION=false

# Browser: set true once, open http://yoursite.test/setup-admin-account , create admin, then set false
ALLOW_WEB_ADMIN_SETUP=false
# Fastest admin login fix (creates/resets user in DB — same DB as .env):
#   php artisan config:clear
#   php artisan viaanoor:create-admin admin@viaanoor.test ViaAdmin123!
# Optional: seed a fixed admin login — run: php artisan db:seed --class=AdminUserSeeder
# Login at /login with this email + password (then remove or empty ADMIN_SEED_PASSWORD on production)
ADMIN_SEED_NAME=Administrator
ADMIN_SEED_EMAIL=admin@viaanoor.test
ADMIN_SEED_PASSWORD=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"
# Where apply-form / ENROLL NOW notifications go (use your mailbox address, not a webmail URL)
MAIL_APPLICATION_TO=admin@viaanur.com
MAIL_CONTACT_TO=admin@viaanur.com
MAIL_SEND_APPLICANT_CONFIRMATION=false
MAIL_ONE_COM_HOSTED=false
MAIL_USE_ONE_COM_PHP_MAIL=false
# Optional: comma-separated extra inboxes as backup copies
MAIL_APPLICATION_BCC=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
